{
    "name": "blackpig-creatif/replique",
    "description": "A Laravel package to add comments to models with a Filament integration",
    "keywords": [
        "BlackpigCreatif",
        "laravel",
        "filamentphp",
        "filament",
        "filament-plugin",
        "replique"
    ],
    "homepage": "https://github.com/blackpig/replique",
    "support": {
        "issues": "https://github.com/blackpig/replique/issues",
        "source": "https://github.com/blackpig/replique"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Blackpig Creatif",
            "email": "stuart@blackpig.eu",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3|^8.4",
        "blackpig-creatif/grimoire": "^2.0",
        "filament/filament": "^5.0",
        "livewire/livewire": "^4.0",
        "spatie/laravel-honeypot": "^4.0",
        "spatie/laravel-package-tools": "^1.15.0"
    },
    "suggest": {
        "league/commonmark": "Required for Markdown text mode (^2.0)"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^10.0|^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "pestphp/pest-plugin-livewire": "^4.0",
        "rector/rector": "^2.0",
        "spatie/laravel-ray": "^1.26"
    },
    "autoload": {
        "psr-4": {
            "BlackpigCreatif\\Replique\\": "src/",
            "BlackpigCreatif\\Replique\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BlackpigCreatif\\Replique\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "lint": "pint",
        "refactor": "rector",
        "test": "pest",
        "test:lint": "pint --test",
        "test:refactor": "rector --dry-run"
    },
    "extra": {
        "laravel": {
            "providers": [
                "BlackpigCreatif\\Replique\\RepliqueServiceProvider"
            ],
            "aliases": {
                "Replique": "BlackpigCreatif\\Replique\\Facades\\Replique"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}